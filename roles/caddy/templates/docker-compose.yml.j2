# {{ ansible_managed }}
services:
  caddy:
    container_name: caddy
    image: {{ caddy_image }}
{% if caddy_tls == 'cloudflare' %}
    env_file: ".env"
{% endif %}
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - './Caddyfile:/etc/caddy/Caddyfile:ro'
      - './data:/data'
      - './config:/config'
