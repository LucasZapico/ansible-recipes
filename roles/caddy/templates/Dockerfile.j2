# {{ ansible_managed }}
# Caddy + caddy-dns/cloudflare (for DNS-01). The stock image ships no DNS
# providers, so a wildcard/internal cert needs this custom build.
FROM caddy:2-builder AS build
RUN xcaddy build --with github.com/caddy-dns/cloudflare

FROM caddy:2
COPY --from=build /usr/bin/caddy /usr/bin/caddy
