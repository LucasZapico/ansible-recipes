# {{ ansible_managed }}
services:
  ntfy:
    container_name: ntfy
    image: {{ ntfy_image }}
    command: serve
    ports:
      - "{{ ntfy_port }}:80"
    volumes:
      - './server.yml:/etc/ntfy/server.yml:ro'
      - './cache:/var/cache/ntfy'
      - './lib:/var/lib/ntfy'
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:80/v1/health || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
    restart: unless-stopped
