# {{ ansible_managed }}
services:
  beszel-agent:
    container_name: beszel-agent
    image: {{ beszel_agent_image }}
    network_mode: host
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    environment:
      LISTEN: "{{ beszel_agent_port }}"
      KEY: "{{ beszel_agent_hub_key }}"
    restart: unless-stopped
